# AgentHands Backend

# Deployer / Agent Wallet (public address)
WALLET_ADDRESS=0xYOUR_WALLET_ADDRESS

# Private Key (for signing transactions — NEVER commit this)
PRIVATE_KEY=0xYOUR_PRIVATE_KEY

# Contract Address (same on both chains)
AGENTHANDS_ADDRESS=0xADA0466303441102cb16F8eC1594C744d603f746

# RPC URLs
BASE_SEPOLIA_RPC=https://sepolia.base.org
CELO_SEPOLIA_RPC=https://forno.celo-sepolia.celo-testnet.org

# Pinata (IPFS)
PINATA_API_KEY=your_pinata_api_key
PINATA_SECRET=your_pinata_secret

# x402
X402_FACILITATOR_URL=https://x402.org/facilitator
